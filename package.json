{
  "name": "adres-pmo",
  "version": "1.0.0",
  "description": "ADRES PMO Platform — venture tracking, dashboards, and reporting",
  "type": "module",
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "build:server": "tsc -p tsconfig.server.json",
    "db:generate": "drizzle-kit generate",
